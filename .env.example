NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 로컬에서는 실제 접속 중인 주소를 입력하세요. 예: http://localhost:3000 또는 http://localhost:3001
# Netlify 배포 후에는 https://your-site.netlify.app 형식으로 바꿉니다.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth Client ID/Secret은 Supabase Dashboard의 Google Provider에만 입력합니다.
